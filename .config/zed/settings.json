// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "scrollbar": {
    "show": "never",
  },
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "languages": {
    "Plain Text": {
      "soft_wrap": "preferred_line_length",
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "Make": {
      "hard_tabs": true,
    },
    "Markdown": {
      "soft_wrap": "editor_width",
    },
    "YAML": {
      "formatter": "language_server",
      "hard_tabs": false,
      "tab_size": 2,
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "off",
    },
  },
  "gutter": {
    "min_line_number_digits": 2,
  },
  "git_panel": {
    "dock": "right",
  },
  "tab_size": 2,
  "hard_tabs": false,
  "vim_mode": true,
  "disable_ai": false,
  "cursor_shape": "block",
  "buffer_line_height": "standard",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "close_window",
  "ui_font_family": ".ZedSans",
  "buffer_font_family": "FiraCode Nerd Font",
  "icon_theme": "Zed (Default)",
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/host_vars/*.yml",
      "**/host_vars/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml",
    ],
    "Jinja2": ["*.j2"],
    "Make": ["Makefile"],
    "env": [".env", ".env.*"],
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/Chart.yaml",
      "**/values.yaml",
      "**/values*.yaml",
      "**/values*.yml",
      "**/helmfile*.yaml",
    ],
  },

  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": "Gruvbox Material",
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "validate": true,
          "hover": true,
          "schemaStore": {
            "enable": true,
            "url": "https://www.schemastore.org/api/json/catalog.json",
          },
          "completion": true,
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yaml",
              "hosts.yml",
            ],
            "kubernetes": [
              "**/*deployment*.yaml",
              "**/*deployment*.yml",
              "**/*service*.yaml",
              "**/*service*.yml",
            ],
          },
        },
      },
    },
  },
}
